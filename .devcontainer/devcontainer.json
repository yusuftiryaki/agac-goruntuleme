{
  "name": "agac-goruntuleme-dev",
  "build": {
    "dockerfile": "../.devcontainer/Dockerfile",
    "context": ".."
  },
  "settings": {
    "terminal.integrated.shell.linux": "/bin/bash"
  },
  "postCreateCommand": "chmod +x .devcontainer/postCreate.sh && .devcontainer/postCreate.sh && chmod +x .devcontainer/token.sh && .devcontainer/token.sh",
  "forwardPorts": [9002],
  "remoteUser": "node",
  "remoteEnv": {
    "GOOGLE_APPLICATION_CREDENTIALS": "/workspaces/agac-goruntuleme$/.private-keys/firebase.json"
  }
}
